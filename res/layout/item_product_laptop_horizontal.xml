<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="350dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:padding="8dp">

        <!-- Badge Giảm giá ở góc trái trên -->
        <TextView
            android:id="@+id/tv_discount_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="#FF4444"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Giảm 14%"
            android:textColor="#212121"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- Badge Trả góp ở góc phải trên -->
        <TextView
            android:id="@+id/tv_installment_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:background="#2196F3"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Trả góp 0%"
            android:textColor="#212121"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- Product Image -->
        <ImageView
            android:id="@+id/iv_product_image"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_below="@id/tv_discount_badge"
            android:layout_marginTop="7dp"
            android:background="#E0E0E0"
            android:contentDescription="Hình ảnh sản phẩm"
            android:scaleType="centerCrop"
            android:src="@drawable/iphone_16_pr" />

        <LinearLayout
            android:layout_width="183dp"
            android:layout_height="127dp"
            android:layout_below="@id/iv_product_image"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <!-- Tên sản phẩm -->
            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="iPhone 16 Pro Max"
                android:textColor="#333333"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Giá hiện tại và giá cũ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_product_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="29.990.000₫"
                    android:textColor="#E91E63"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Smember discount -->
            <TextView
                android:id="@+id/tv_product_old_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="1dp"
                android:text="34.990.000₫"
                android:textColor="#999999"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="#F3E5F5"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Smember giảm đến 1.000.000₫"
                android:textColor="#9C27B0"
                android:textSize="10sp" />

            <!-- S-Student discount -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="#E3F2FD"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="S-Student giảm thêm 500.000₫"
                android:textColor="#1565C0"
                android:textSize="10sp" />

            <!-- Đánh giá -->
            <TextView
                android:id="@+id/tv_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="4.9 ⭐"
                android:textColor="#FF9800"
                android:textSize="10sp" />

        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>