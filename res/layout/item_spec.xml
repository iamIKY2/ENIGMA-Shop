<?xml version="1.0" encoding="utf-8"?>
<!-- Nền bo góc, padding lớn, bóng đổ nhẹ cho item thông số -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_spec_item"
    android:padding="12dp"
    android:layout_marginVertical="6dp"
    android:elevation="2dp">

    <!-- Tên thông số, in đậm, màu nổi bật -->
    <TextView
        android:id="@+id/tv_spec_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#1A237E"
        android:textStyle="bold"
        android:textSize="16sp"
        android:padding="6dp"
        android:background="@android:color/transparent"/>

    <!-- Giá trị thông số, màu nhẹ nhàng -->
    <TextView
        android:id="@+id/tv_spec_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#37474F"
        android:textSize="16sp"
        android:padding="6dp"
        android:background="#F5F5F5"/>
</LinearLayout>