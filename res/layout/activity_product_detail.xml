<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Tên thiết bị -->
        <TextView
            android:id="@+id/tv_device_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên thiết bị"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingBottom="8dp" />

        <!-- Tính năng nổi bật -->
        <TextView
            android:id="@+id/tv_highlight_features"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tính năng nổi bật"
            android:textSize="16sp"
            android:textColor="#1976D2"
            android:paddingBottom="8dp" />

        <!-- Chọn màu -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn màu:"
            android:textStyle="bold"
            android:paddingTop="8dp" />
        <Spinner
            android:id="@+id/spinner_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <!-- Chọn dung lượng -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn dung lượng:"
            android:textStyle="bold" />
        <Spinner
            android:id="@+id/spinner_storage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <!-- Thông số kỹ thuật -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông số kỹ thuật:"
            android:textStyle="bold"
            android:paddingTop="8dp" />
        <TextView
            android:id="@+id/tv_specifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thông số kỹ thuật chi tiết"
            android:paddingBottom="8dp" />

        <!-- Đánh giá -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đánh giá:"
            android:textStyle="bold"
            android:paddingTop="8dp" />
        <TextView
            android:id="@+id/tv_reviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4.9 ⭐ (1000 đánh giá)"
            android:paddingBottom="8dp" />

        <!-- Giá tiền và giỏ hàng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="16dp">

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="29.990.000₫"
                android:textColor="#E91E63"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_add_to_cart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm vào giỏ hàng"
                android:background="#1976D2"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView> 